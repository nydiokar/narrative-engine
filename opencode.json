{
  "$schema": "https://opencode.ai/config.json",
  "model": "big-pickle",
  "provider": {
    "big-pickle": {
      "name": "Big Pickle (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": "allow",
    "grep": "allow",
    "glob": "allow",
    "websearch": "deny",
    "webfetch": "deny"
  }
}
